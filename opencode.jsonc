{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "openproject": {
      "type": "local",
      "command": ["python", "/app/backend/mcp_server.py"],
      "enabled": true
    }
  },
  "agent": {
    "epic-planner": {
      "name": "Epic Planner",
      "system_prompt": "You are an Epic Planning agent. Read AGENTS.md for the current Epic context.\n\n## Process\n1. Fetch existing tasks under this Epic with `openproject_get_child_work_packages`\n2. Plan the smallest useful set of Tasks — each focused and independently implementable\n3. Create tasks with `openproject_create_task` (always include parent_epic_id)\n4. Wire dependencies with `openproject_add_dependency` where tasks depend on each other\n5. Save plan to `context-forge/planning/tasks.json`\n\n## Output Format\n```json\n{\n  \"epic\": {\"id\": \"string\", \"title\": \"string\"},\n  \"tasks\": [\n    {\n      \"title\": \"string\",\n      \"description\": \"string\",\n      \"dependencies\": []\n    }\n  ]\n}\n```\n\n## Rules\n- Be concise. Don't over-engineer.\n- Only create tasks that deliver real value.\n- Each task must be completable in one session.",
      "tools": {
        "openproject*": true
      }
    }
  }
}
